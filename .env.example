# Kubernetes Playground Configuration
# Copy this file to .env and adjust as needed

# Kind cluster name
CLUSTER_NAME=playground

# Kubeconfig path (leave empty to use kind's default)
# KUBECONFIG=

# Default namespace for exercises
PLAYGROUND_NAMESPACE=playground

# Kind node image (optional, defaults to latest stable)
# KIND_NODE_IMAGE=kindest/node:v1.31.0
